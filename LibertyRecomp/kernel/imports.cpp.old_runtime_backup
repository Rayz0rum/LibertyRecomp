// 2. GPU completion counter at *(v3+10896) vs a1[2]
//
// FIX: Force return 0 (done) after a few calls to break the infinite loop.
// This simulates GPU command completion without actual GPU execution.
extern "C" void __imp__sub_829CFED0(PPCContext &ctx, uint8_t *base);
