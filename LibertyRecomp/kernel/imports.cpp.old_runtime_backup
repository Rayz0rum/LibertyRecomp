// sub_8298E700 - audio worker task function
// Analysis: This worker uses virtual dispatch (vtable[3]) and loops forever
// waiting on semaphore Worker pattern:
//   1. Signal sem2 (ctx+40) - tells creator "I'm running"
//   2. Wait on sem1 (ctx+36) - wait for work (BLOCKS forever - sem1 never
//   signaled)
//   3. Call vtable[3] (ctx+0 → vtable → offset 12) - audio processing
//   4. Loop back to step 2
//
// FIX: Signal sem2, call vtable[3] once for audio, then return (no blocking)
extern "C" void __imp__sub_8298E700(PPCContext &ctx, uint8_t *base);
PPC_FUNC(sub_8298E700) {
  static int s_count = 0;
  ++s_count;
  uint32_t ctx_ptr = ctx.r3.u32;

  // Read struct fields
  uint32_t sem2 = 0;
  if (ctx_ptr >= 0x82000000 && ctx_ptr < 0x90000000) {
    sem2 = ByteSwap(
        *(uint32_t *)g_memory.Translate(ctx_ptr + 40)); // signal semaphore
  }

  if (s_count <= 5) {
    LOGF_WARNING("[AUDIO_WORKER] sub_8298E700 #{} ctx=0x{:08X} sem2=0x{:08X}",
                 s_count, ctx_ptr, sem2);
  }

  // Signal sem2 so sub_8298E810 can continue, then return
  // Skip the vtable call - audio processing handled by audio thread
  if (sem2 != 0) {
    SignalSemaphoreByGuestAddr(sem2);
  }

  // Set termination flag so worker doesn't loop
  if (ctx_ptr >= 0x82000000 && ctx_ptr < 0x90000000) {
    uint8_t *flagPtr = (uint8_t *)g_memory.Translate(ctx_ptr + 48);
    *flagPtr |= 0x80; // Set termination flag
  }

  // Step 3: Signal audio events to wake AudioThread
  // DEADLOCK FIX: Do NOT call sub_82172BE8 which tail-calls sub_82169B00.
  // sub_82169B00 acquires critical section 0x82AA06D0 then calls
  // KeWaitForMultipleObjects. If AudioThread already holds that lock while
  // waiting, worker threads deadlock.
  //
  // EVENT CHAIN ANALYSIS:
  //   sub_82169B00 signals byte_83137B80, then waits on byte_83137B5C OR
  //   byte_83137BA0 sub_82169400 waits on byte_83137B80, does work, signals
  //   byte_83137B5C
  //
  // FIX: Signal byte_83137B5C directly to wake AudioThread waiting in
  // sub_82169B00. Also signal byte_83137B80 to wake sub_82169400 if it's
  // waiting.
  constexpr uint32_t AUDIO_WORKER_DONE_EVENT =
      0x83137B5C; // byte_83137B5C - wakes AudioThread
  constexpr uint32_t AUDIO_TRIGGER_EVENT =
      0x83137B80; // byte_83137B80 - wakes sub_82169400
  static bool s_eventLogged = false;

  // Signal byte_83137B5C to wake AudioThread (this is what it's waiting on)
  SignalEventByGuestAddr(AUDIO_WORKER_DONE_EVENT);

  // Also signal byte_83137B80 to wake sub_82169400 worker
  SignalEventByGuestAddr(AUDIO_TRIGGER_EVENT);

  if (!s_eventLogged) {
    LOG_WARNING("[AUDIO_WORKER] Signaling audio events directly: "
                "0x83137B5C (worker done) + 0x83137B80 (trigger)");
    s_eventLogged = true;
  }

  ctx.r3.u32 = 0; // Return success
  return;
}

