    ctx.r3.u32 = 0;         // Return 0 = done waiting
    s_consecutiveCalls = 0; // Reset for next sync point
    return;
  }

  // Call original - it will return 1 (keep waiting) if GPU not done
  __imp__sub_829CFED0(ctx, base);

  // If original returned 0 (done), reset consecutive counter
  if (ctx.r3.u32 == 0) {
    s_consecutiveCalls = 0;
  }
