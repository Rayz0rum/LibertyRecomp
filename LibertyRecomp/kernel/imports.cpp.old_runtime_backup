  static int s_consecutiveCalls = 0;

  // Track consecutive calls - if we're in a tight loop, force completion
  ++s_consecutiveCalls;

  if (s_count <= 5 || s_count % 10000 == 0) {
    LOGF_WARNING("[GPU_SYNC] sub_829CFED0 #{} consecutive={}", s_count,
                 s_consecutiveCalls);
  }

  // After 50 consecutive calls, force return 0 (done waiting)
  // This breaks the infinite GPU sync loop
  if (s_consecutiveCalls > 50) {
    if (s_consecutiveCalls == 51 || s_consecutiveCalls % 1000 == 0) {
