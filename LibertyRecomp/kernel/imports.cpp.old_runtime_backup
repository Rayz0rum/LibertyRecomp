// Check if a handle belongs to RexGlue's ObjectTable (slot-based handles)
// RexGlue uses kHandleBase = 0xF8000000; handles are 0xF8000004, 0xF8000008, etc.
// Liberty's guest-address handles are 0x80000000-0xEFFFFFFF range.
// PC file synthetic handles are 0x50xxxxxx range.
static inline bool IsRexGlueHandle(uint32_t handle) {
    return handle >= 0xF8000000 && handle < 0xFC000000;
}

