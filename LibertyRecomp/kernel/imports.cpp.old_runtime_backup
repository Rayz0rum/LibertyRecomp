// Helper: Read null-terminated string from guest memory (max 256 chars)
// NOTE: Guest addresses (0x8200xxxx etc) are used directly as offsets from
// base, matching PPC_LOAD_U8/U32 macros which use `base + x` without masking.
static bool ReadGuestString(uint8_t *base, uint32_t guestPtr, char *outBuf,
                            size_t bufSize) {
  // Validate pointer is in valid PPC memory ranges:
  // 0x00000000-0x40000000 = user heap
  // 0x80000000-0xA0000000 = XEX code/data region
  // 0xA0000000-0xE0000000 = kernel objects, heap extensions
  bool validRange = (guestPtr < 0x40000000) ||
