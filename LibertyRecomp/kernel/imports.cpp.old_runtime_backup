// PHASE 1: Deep Instrumentation - File Parsing Chain
// =============================================================================
// Global helper to read string from guest memory
static std::string ReadGuestString(uint8_t *base, uint32_t addr,
                                   int maxLen = 260) {
  if (addr < 0x80000000 || addr >= 0x90000000)
    return "<invalid addr>";
  std::string result;
  for (int i = 0; i < maxLen; i++) {
    uint8_t c = *(base + addr + i);
    if (c == 0)
      break;
    if (c >= 0x20 && c <= 0x7E)
      result += (char)c;
    else
      result += '.';
  }
  return result.empty() ? "<empty>" : result;
}

