// PC file handle table - NtFileHandle must be allocated in HOST memory (not
// guest) because std::fstream has internal pointers/vtables that must be in
// host address space. This table maps synthetic handles (0x50xxxxxx) to
// host-allocated NtFileHandle pointers.
static std::unordered_map<uint32_t, NtFileHandle *> s_pcFileHandleTable;
static uint32_t s_nextPcHandle = 0x50000001;
static std::mutex s_pcHandleMutex;

static uint32_t RegisterPcHandle(NtFileHandle *hFile) {
  std::lock_guard<std::mutex> lock(s_pcHandleMutex);
  uint32_t handle = s_nextPcHandle++;
  s_pcFileHandleTable[handle] = hFile;
  return handle;
}

static NtFileHandle *GetPcHandle(uint32_t handle) {
  std::lock_guard<std::mutex> lock(s_pcHandleMutex);
  auto it = s_pcFileHandleTable.find(handle);
  if (it != s_pcFileHandleTable.end()) {
    return it->second;
  }
  return nullptr;
}

// Check if a handle belongs to any Liberty file/dir/virt handle map.
// Needed because Liberty allocates file handles in the 0x50xxxxxx range
// which don't pass IsKernelObject()'s bit-31 check.
static bool IsFileHandle(uint32_t handle) {
  return g_ntFileHandles.count(handle) || g_ntDirHandles.count(handle) ||
         g_ntVirtFileHandles.count(handle);
}

