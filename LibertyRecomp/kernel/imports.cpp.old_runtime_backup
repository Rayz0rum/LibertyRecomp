// =============================================================================
// sub_829A64C0 - Heap Allocation with Corruption Recovery
// =============================================================================
// The heap structure is being corrupted - both the critical section at offset
// 1408 and the free list pointers at offsets 384/388 are being zeroed. This
// wrapper caches the initial valid state and restores it when corruption is
// detected.
static uint32_t s_cachedCritSecPtr = 0;
static uint32_t s_cachedFreeListHead = 0;
static uint32_t s_cachedFreeListNext = 0;
static uint32_t s_cachedHeapAddr = 0;
static bool s_heapCached = false;

extern "C" void __imp__sub_829A64C0(PPCContext &ctx, uint8_t *base);
#if !defined(REX_USE_FULL_SDK)
PPC_FUNC(sub_829A64C0) {
  static int s_count = 0;
  ++s_count;
  static int s_fixCount = 0;

  // Force HEAP_ZERO_MEMORY flag (0x8) on ALL allocations
  // Xbox 360 allocators return zeroed memory, game code expects this behavior
  // Without this, reused memory blocks contain garbage causing hash table
  // corruption
  ctx.r4.u32 |= 0x8;

  uint32_t heapArg = ctx.r3.u32;

  if (heapArg == 0) {
    ctx.r3.u32 = 0;
    return;
  }

  uint32_t critSecPtr = PPC_LOAD_U32(heapArg + 1408);
  uint32_t freeListHead = PPC_LOAD_U32(heapArg + 384);
  uint32_t freeListNext = PPC_LOAD_U32(heapArg + 388);

  // Cache the valid heap state on first valid call
  if (!s_heapCached && critSecPtr != 0 && freeListHead != 0) {
    s_cachedCritSecPtr = critSecPtr;
    s_cachedFreeListHead = freeListHead;
    s_cachedFreeListNext = freeListNext;
    s_cachedHeapAddr = heapArg;
    s_heapCached = true;
    LOGF_WARNING("[HEAP_ALLOC] Cached heap state: heap=0x{:08X} "
                 "critSec=0x{:08X} freeList=0x{:08X}/0x{:08X}",
                 heapArg, critSecPtr, freeListHead, freeListNext);
  }

  // Detect and restore corruption
  if (heapArg == s_cachedHeapAddr && s_heapCached) {
    bool corrupted = false;

    // Check critical section
    if (critSecPtr == 0 && s_cachedCritSecPtr != 0) {
      PPC_STORE_U32(heapArg + 1408, s_cachedCritSecPtr);
      corrupted = true;
    }

    // Check free list head - if zeroed but we have cache, restore
    // Note: Free list can legitimately change, so only restore if it's NULL
    if (freeListHead == 0 && s_cachedFreeListHead != 0) {
      PPC_STORE_U32(heapArg + 384, s_cachedFreeListHead);
      PPC_STORE_U32(heapArg + 388, s_cachedFreeListNext);
      corrupted = true;
    }

    if (corrupted && ++s_fixCount <= 5) {
      LOGF_WARNING("[HEAP_ALLOC] #{} Restored corrupted heap structure",
                   s_count);
    }
  }

  // Re-check critical section after restoration
  critSecPtr = PPC_LOAD_U32(heapArg + 1408);
  if (critSecPtr == 0) {
    if (s_count <= 5) {
      LOG_WARNING("[HEAP_ALLOC] Cannot recover critSec - returning 0");
    }
    ctx.r3.u32 = 0;
    return;
  }

  __imp__sub_829A64C0(ctx, base);
}
