// =============================================================================
// sub_828935B8 - AUDIO ALLOCATOR (PLATFORM GLUE REPLACEMENT)
// =============================================================================
// XEX Source Analysis:
//   return (*(int (__fastcall **)(_DWORD, int, int, _DWORD))(**(_DWORD **)(a1 +
//   1300) + 8))(
//            *(_DWORD *)(a1 + 1300), a2, a3, 0);
//
// This is a vtable-based allocator used by audio config loading (sub_8289D1D0).
// The vtable at [a1+1300] may not be properly initialized, causing:
//   - Bad pointer returns -> writes to invalid memory
//   - Heap metadata corruption -> crash in o1heapAllocate
//
// Solution: Replace with direct allocation using g_userHeap.
// =============================================================================
// Track the last large audio allocation for speech.dat buffer base
// Memory: URLs use offsets relative to this buffer
static uint32_t g_speechDatBufferBase = 0;
static uint32_t g_speechDatBufferSize = 0;

extern "C" void __imp__sub_828935B8(PPCContext &ctx, uint8_t *base);
PPC_FUNC(sub_828935B8) {
  static int s_count = 0;
  ++s_count;

  // Parameters from XEX: sub_828935B8(a1=audio_mgr, a2=size, a3=alignment)
  uint32_t audioMgr = ctx.r3.u32;
  uint32_t allocSize = ctx.r4.u32;
  uint32_t alignment = ctx.r5.u32;

  if (alignment == 0)
    alignment = 16;
  if (allocSize == 0) {
    ctx.r3.u64 = 0;
    return;
  }

  // PLATFORM GLUE: Use AllocPhysical to get memory in guest-addressable range
  // g_userHeap.Alloc() returns host heap memory which is NOT in PPC range
  // g_userHeap.AllocPhysical() allocates within guest memory range so
  // MapVirtual works correctly
  void *hostPtr = g_userHeap.AllocPhysical(allocSize, alignment);
  if (hostPtr) {
    // Explicit memset - Xbox 360 allocators return zeroed memory
    memset(hostPtr, 0, allocSize);
    uint32_t guestAddr = g_memory.MapVirtual(hostPtr);
    ctx.r3.u64 = guestAddr;

    // Track speech.dat buffer (allocated during sub_828A58C8)
    // speech.dat is ~544KB, so look for allocations around that size
    if (allocSize >= 500000 && allocSize <= 600000) {
      g_speechDatBufferBase = guestAddr;
      g_speechDatBufferSize = allocSize;
      LOGF_WARNING("[sub_828935B8] SPEECH_DAT_BUFFER: 0x{:08X} size={} "
                   "hostPtr={}",
                   guestAddr, allocSize, (void *)hostPtr);
    }

    if (s_count <= 20 || s_count % 500 == 0) {
      printf("[sub_828935B8] AUDIO_ALLOC #%d: %u bytes align=%u -> 0x%08X\n",
             s_count, allocSize, alignment, guestAddr);
      fflush(stdout);
    }
  } else {
    ctx.r3.u64 = 0;
    LOGF_WARNING("[sub_828935B8] AUDIO_ALLOC #{} FAILED for {} bytes", s_count,
                 allocSize);
  }
}

